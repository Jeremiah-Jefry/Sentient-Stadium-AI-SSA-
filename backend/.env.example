# StadiumMind OS - Environment Configuration
# Copy to .env and fill in values. Never commit .env files.

# Application
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
APP_ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://stadiummind:CHANGE_ME@localhost:5432/stadiummind_iam
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Firebase
FIREBASE_PROJECT_ID=stadiummind-fifa2026
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
FIREBASE_DATABASE_URL=https://stadiummind-fifa2026.firebaseio.com

# JWT
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=stadiummind-iam

# Redis (session store & rate limiting)
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=86400
REDIS_RATE_LIMIT_WINDOW_SECONDS=60

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@stadiummind.io

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
